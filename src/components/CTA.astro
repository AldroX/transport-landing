<section class="py-20 text-center">
  <div class="mx-auto max-w-[1100px] px-6">
    <div
      class="noise-overlay relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-dark-warm px-10 py-14 text-white sm:px-14 sm:py-16"
    >
      <div class="relative z-10">
        <h2 class="reveal font-heading text-2xl sm:text-[2rem]">
          ¿Listo para mover tu carga?
        </h2>
        <p class="reveal reveal-delay-1 mx-auto mb-8 mt-3 max-w-[500px] text-white/70">
          Cotización sin compromiso en menos de 2 horas. Atención personalizada
          para cada envío.
        </p>

        <a
          href="#cotizar"
          class="reveal reveal-delay-2 inline-flex items-center gap-2 rounded-lg bg-accent px-8 py-3.5 font-heading text-sm text-dark no-underline shadow-button transition-all hover:-translate-y-1 hover:shadow-hover"
        >
          Cotizar ahora
        </a>

        <div class="reveal reveal-delay-3 mt-8 flex flex-wrap items-center justify-center gap-8">
          <a
            class="flex items-center gap-2 text-[1.05rem] font-semibold text-accent no-underline hover:underline"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            +53 55 1x xx
          </a>
          <a
            class="flex items-center gap-2 text-[1.05rem] font-semibold text-accent no-underline hover:underline"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            ventas@rastrastransport
          </a>
          <a
            href="#"
            class="flex items-center gap-2 text-[1.05rem] font-semibold text-accent no-underline hover:underline"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.5 8.5 0 0 1-8.5 8.5H8l-4 2 1.5-4.5A8.5 8.5 0 1 1 21 11.5z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
