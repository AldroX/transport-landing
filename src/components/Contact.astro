---
---

<section class="bg-light py-20" id="cotizar">
  <div class="mx-auto max-w-275 px-6">
    <div class="grid grid-cols-1 items-start gap-10 lg:grid-cols-2">
      <!-- Left: Info -->
      <div class="reveal">
        <h2 class="section-accent font-heading text-[1.8rem] text-dark">
          Solicita tu Cotización
        </h2>
        <p class="mb-7 mt-4 leading-relaxed text-gray">
          Completa el formulario y te enviamos una propuesta personalizada
          directo a tu WhatsApp.
        </p>
        <ul class="list-none space-y-3">
          <li class="flex items-center gap-2.5 text-dark">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e8a838" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Sin compromiso — la cotización es gratuita
          </li>
          <li class="flex items-center gap-2.5 text-dark">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e8a838" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Seguro de carga incluido en todos los viajes
          </li>
          <li class="flex items-center gap-2.5 text-dark">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e8a838" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Rastreo GPS en tiempo real
          </li>
          <li class="flex items-center gap-2.5 text-dark">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e8a838" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Atención 24/7 para emergencias
          </li>
          <li class="flex items-center gap-2.5 text-dark">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e8a838" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Descuentos por volumen recurrente
          </li>
        </ul>
      </div>

      <!-- Right: Form -->
      <form
        class="reveal reveal-delay-1 rounded-xl bg-white px-9 py-9 shadow-card"
        onsubmit="handleContactSubmit(event)"
      >
        <h3 class="mb-6 font-heading text-[1.3rem] text-dark">
          Datos del envío
        </h3>

        <div class="mb-4.5">
          <label for="nombre" class="mb-1.5 block font-heading text-[.88rem] text-dark"
            >Nombre completo *</label
          >
          <input
            type="text" id="nombre" required placeholder="Tu nombre"
            class="w-full rounded-lg border border-gray-light bg-light px-3.5 py-3 text-[.95rem] text-dark outline-none transition-all focus:border-accent focus:ring-2 focus:ring-accent/20"
          />
        </div>

        <div class="mb-4.5">
          <label for="empresa" class="mb-1.5 block font-heading text-[.88rem] text-dark"
            >Empresa</label
          >
          <input
            type="text" id="empresa" placeholder="Nombre de tu empresa"
            class="w-full rounded-lg border border-gray-light bg-light px-3.5 py-3 text-[.95rem] text-dark outline-none transition-all focus:border-accent focus:ring-2 focus:ring-accent/20"
          />
        </div>

        <div class="mb-4.5 grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label for="origen" class="mb-1.5 block font-heading text-[.88rem] text-dark"
              >Puerto / Origen *</label
            >
            <input
              type="text" id="origen" required placeholder="Ej: Puerto de Veracruz"
              class="w-full rounded-lg border border-gray-light bg-light px-3.5 py-3 text-[.95rem] text-dark outline-none transition-all focus:border-accent focus:ring-2 focus:ring-accent/20"
            />
          </div>
          <div>
            <label for="destino" class="mb-1.5 block font-heading text-[.88rem] text-dark"
              >Destino *</label
            >
            <input
              type="text" id="destino" required placeholder="Ej: Ciudad de México"
              class="w-full rounded-lg border border-gray-light bg-light px-3.5 py-3 text-[.95rem] text-dark outline-none transition-all focus:border-accent focus:ring-2 focus:ring-accent/20"
            />
          </div>
        </div>

        <div class="mb-4.5 grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label for="tipo-carga" class="mb-1.5 block font-heading text-[.88rem] text-dark"
              >Tipo de carga *</label
            >
            <select
              id="tipo-carga" required
              class="w-full rounded-lg border border-gray-light bg-light px-3.5 py-3 text-[.95rem] text-dark outline-none transition-all focus:border-accent focus:ring-2 focus:ring-accent/20"
            >
              <option value="">Seleccionar...</option>
              <option>Carga general</option>
              <option>Paquetería</option>
              <option>Refrigerada</option>
              <option>Industrial / Pesada</option>
              <option>Contenedor</option>
              <option>Otro</option>
            </select>
          </div>
          <div>
            <label for="peso" class="mb-1.5 block font-heading text-[.88rem] text-dark"
              >Peso aproximado (kg)</label
            >
            <input
              type="number" id="peso" placeholder="Ej: 5000"
              class="w-full rounded-lg border border-gray-light bg-light px-3.5 py-3 text-[.95rem] text-dark outline-none transition-all focus:border-accent focus:ring-2 focus:ring-accent/20"
            />
          </div>
        </div>

        <div class="mb-4.5">
          <label for="detalles" class="mb-1.5 block font-heading text-[.88rem] text-dark"
            >Detalles adicionales</label
          >
          <textarea
            id="detalles" rows="4"
            placeholder="Describe tu carga, fechas preferidas, requisitos especiales..."
            class="min-h-22.5 w-full resize-y rounded-lg border border-gray-light bg-light px-3.5 py-3 text-[.95rem] text-dark outline-none transition-all focus:border-accent focus:ring-2 focus:ring-accent/20"
          ></textarea>
        </div>

        <button
          type="submit"
          class="group flex w-full cursor-pointer items-center justify-center gap-2.5 rounded-lg bg-accent px-4 py-3.5 font-heading text-[1rem] text-dark no-underline shadow-button transition-all hover:-translate-y-1 hover:bg-accent-hover hover:shadow-hover"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:scale-110">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
          Cotizar por WhatsApp
        </button>
        <p class="mt-3 text-center text-[.8rem] text-gray">
          Te respondemos en menos de 2 horas.
        </p>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  function handleContactSubmit(e) {
    e.preventDefault();
    const f = e.target;

    const nombre = f.querySelector('#nombre').value.trim();
    const empresa = f.querySelector('#empresa').value.trim();
    const origen = f.querySelector('#origen').value.trim();
    const destino = f.querySelector('#destino').value.trim();
    const tipoCarga = f.querySelector('#tipo-carga').value;
    const peso = f.querySelector('#peso').value.trim();
    const detalles = f.querySelector('#detalles').value.trim();

    let mensaje = '¡Hola! Quiero solicitar una cotización de transporte.\n';
    mensaje += `\n*Nombre:* ${nombre}`;
    mensaje += `\n*Origen:* ${origen}`;
    mensaje += `\n*Destino:* ${destino}`;
    mensaje += `\n*Tipo de carga:* ${tipoCarga}`;
    if (empresa) mensaje += `\n*Empresa:* ${empresa}`;
    if (peso) mensaje += `\n*Peso:* ${peso} kg`;
    if (detalles) mensaje += `\n*Detalles:* ${detalles}`;

    const url = `https://wa.me/5359137704?text=${encodeURIComponent(mensaje)}`;
    window.open(url, '_blank');
  }
</script>
