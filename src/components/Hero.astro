---
import heroBg from '../assets/imgs/sander-yigin-ki19VJAGh6w-unsplash.jpg';
---

<section
  class="hero-curve noise-overlay relative flex min-h-screen items-center justify-center overflow-hidden text-white"
>
  <!-- Gradient overlay (static) -->
  <div class="absolute inset-0 z-10 bg-gradient-to-br from-dark/85 to-primary/75" />

  <!-- Background image with parallax -->
  <img
    id="hero-parallax"
    class="absolute left-0 top-[-15%] z-0 h-[130%] w-full object-cover object-center will-change-transform"
    src={heroBg.src}
    alt="Rastra de carga en carretera — Transporte de mercancías por carretera"
    loading="eager"
    data-speed="0.12"
  />

  <!-- Content with stagger reveals -->
  <div class="relative z-20 mx-auto px-6 pt-36 pb-28 text-center">
    <h1 class="reveal mb-4 font-heading text-[clamp(2rem,5vw,3.2rem)] leading-tight">
      Tu carga del <span class="text-accent">Puerto a tu negocio</span
      ><br class="hidden sm:inline" />
      de forma segura y puntual
    </h1>
    <p class="reveal reveal-delay-1 mx-auto mb-9 max-w-[600px] text-lg text-white/75">
      Transporte especializado de mercancías con rastras de última generación.
      Rastreo en tiempo real, seguros completos y entregas garantizadas.
    </p>
    <div class="reveal reveal-delay-2 flex flex-wrap justify-center gap-4">
      <a
        href="#cotizar"
        class="inline-flex items-center gap-2 rounded-lg bg-accent px-8 py-3.5 font-heading text-sm text-dark no-underline shadow-button transition-all hover:-translate-y-1 hover:shadow-hover"
      >
        Solicitar cotización
      </a>
      <a
        href="#como-funciona"
        class="inline-flex items-center gap-2 rounded-lg border-2 border-white/30 bg-transparent px-8 py-3.5 font-heading text-sm text-white no-underline transition-all hover:-translate-y-1 hover:border-accent hover:text-accent"
      >
        Cómo funciona →
      </a>
    </div>
  </div>

  <!-- Curved bottom separator -->
  <div
    class="pointer-events-none absolute bottom-0 left-0 z-20 h-15 w-full"
    aria-hidden="true"
  ></div>
</section>

<script is:inline>
  (function () {
    const img = document.getElementById('hero-parallax');
    if (!img) return;
    const speed = parseFloat(img.getAttribute('data-speed') || '0.15');
    let ticking = false;

    function updateParallax() {
      const scrollY = window.scrollY;
      const maxTranslate = window.innerHeight * speed * 0.5;
      const translateY = Math.min(scrollY * speed, maxTranslate);
      img.style.transform = 'translateY(' + translateY + 'px)';
      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(updateParallax);
        ticking = true;
      }
    });
  })();
</script>

<style>
  .hero-curve::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    z-index: 20;
    width: 100%;
    height: 60px;
    background: white;
    clip-path: ellipse(55% 100% at 50% 100%);
    pointer-events: none;
  }
</style>
